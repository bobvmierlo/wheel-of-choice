# Watches for the update-requested flag the app's admin button drops
# into the state directory, then starts wheel-of-choice-update.service.
# See wheel-of-choice-update.service for install instructions.

[Unit]
Description=Wheel of Choice — watch for update requests

[Path]
PathExists=/var/lib/wheel-of-choice/update-requested

[Install]
WantedBy=multi-user.target
